---
import site from '../data/site.json';
const c = site.contact;
const b = site.brand;
---

<section id="contacto" class="section-pad bg-gray-50">
  <div class="container-site">
    <div class="grid lg:grid-cols-5 gap-10 sm:gap-16 items-start">
      <div class="lg:col-span-2">
        <span class="badge mb-4">Contacto</span>
        <h2 class="heading-lg mb-4">{c.title}</h2>
        <p class="text-gray-500 text-sm sm:text-base mb-8 leading-relaxed">{c.description}</p>
        <div class="space-y-5">
          <a href={`tel:${c.phone}`} class="flex items-center gap-4 text-gray-700 hover:text-blue-700 transition-colors">
            <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div><div class="text-sm font-semibold">Teléfono</div><div class="text-sm text-gray-500">{c.phone}</div></div>
          </a>
          <a href={`mailto:${c.email}`} class="flex items-center gap-4 text-gray-700 hover:text-blue-700 transition-colors">
            <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div><div class="text-sm font-semibold">Email</div><div class="text-sm text-gray-500">{c.email}</div></div>
          </a>
          <a href={`https://wa.me/${c.whatsapp}`} target="_blank" class="flex items-center gap-4 text-gray-700 hover:text-green-600 transition-colors">
            <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div><div class="text-sm font-semibold">WhatsApp</div><div class="text-sm text-gray-500">Chatea con nosotros</div></div>
          </a>
        </div>
      </div>
      <div class="lg:col-span-3">
        <form class="card p-6 sm:p-8" action="https://formspree.io/f/your-form-id" method="POST">
          <h3 class="font-bold text-lg mb-6">Envíanos tu consulta</h3>
          <div class="grid sm:grid-cols-2 gap-4 sm:gap-5">
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Nombre completo</label>
              <input type="text" name="name" required class="w-full h-11 px-4 border border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none transition-all" placeholder="Tu nombre" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Email</label>
              <input type="email" name="email" required class="w-full h-11 px-4 border border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none transition-all" placeholder="tu@email.com" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Teléfono</label>
              <input type="tel" name="phone" class="w-full h-11 px-4 border border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none transition-all" placeholder="+56 9 XXXX XXXX" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Empresa</label>
              <input type="text" name="company" class="w-full h-11 px-4 border border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none transition-all" placeholder="Nombre de tu empresa" />
            </div>
            <div class="sm:col-span-2">
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Mensaje</label>
              <textarea name="message" rows="3" class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none transition-all resize-none" placeholder="Cuéntanos qué necesitas..."></textarea>
            </div>
          </div>
          <button type="submit" class="btn-primary mt-5 w-full justify-center">Enviar cotización →</button>
        </form>
      </div>
    </div>
  </div>
</section>
