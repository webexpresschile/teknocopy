---
import site from '../data/site.json';
const services = site.services;
---

<section id="servicios" class="section-pad bg-gray-50">
  <div class="container-site">
    <div class="text-center mb-12 sm:mb-16">
      <span class="badge mb-4">Servicios</span>
      <h2 class="heading-lg mb-4">Soluciones de impresión para tu empresa</h2>
      <p class="text-gray-500 max-w-2xl mx-auto text-sm sm:text-base">Equipos, soporte e insumos. Todo lo que necesitas para mantener tu operación funcionando sin interrupciones.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {services.map(s => (
        <div class="card p-6 sm:p-8 flex flex-col">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-3">{s.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-5 flex-1">{s.description}</p>
          <ul class="space-y-2 mb-5">
            {s.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <svg class="w-4 h-4 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#contacto" class="text-blue-700 font-semibold text-sm hover:text-blue-800 transition-colors inline-flex items-center gap-1.5">
            Consultar →</a>
        </div>
      ))}
    </div>
  </div>
</section>
